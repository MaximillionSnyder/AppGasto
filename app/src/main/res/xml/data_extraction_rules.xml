<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="appgasto_database"/>
        <include domain="sharedpref" path="com.example.appgasto_preferences.xml"/>
        <include domain="file" path="backups/"/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="appgasto_database"/>
        <include domain="sharedpref" path="com.example.appgasto_preferences.xml"/>
        <include domain="file" path="backups/"/>
    </device-transfer>
</data-extraction-rules>